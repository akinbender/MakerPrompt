@inject PrinterConnectionManager ConnectionManager
@implements IDisposable

<nav class="navbar navbar-expand px-2">
    <div class="container-fluid">
        <div class="me-2">
            <div class="collapse navbar-collapse" id="navbarNavDropdown">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="printers/dashboard" title="Open multi-printer dashboard">
                            <i class="bi bi-grid-1x2 me-1"></i>
                            Fleet
                        </a>
                    </li>
                    <li class="nav-item d-flex align-items-center ms-2">
                        <span class="badge @(ActiveConnectionCount > 0 ? "text-bg-success" : "text-bg-secondary")" title="Active printer connections">
                            @ActiveConnectionCount
                        </span>
                    </li>
                    <CultureSelector />
                    <ThemeSelector />
                    <li class="nav-item">
                        <a class="nav-link" href="https://github.com/akinbender/MakerPrompt" target="_blank" rel="noopener noreferrer" title="GitHub">
                            <i class="bi bi-github"></i>
                        </a>
                    </li>
                    <li class="nav-item d-md-none">
                        <button class="nav-link px-3 text-white" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarMenu" aria-controls="sidebarMenu" aria-expanded="false" aria-label="Toggle navigation"><span class="navbar-toggler-icon"></span></button>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</nav>

@code {
    private int ActiveConnectionCount { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await ConnectionManager.InitializeAsync();
        ActiveConnectionCount = ConnectionManager.ActiveConnections.Count;
        ConnectionManager.StatesChanged += HandleStatesChanged;
        await base.OnInitializedAsync();
    }

    private void HandleStatesChanged(object? sender, IReadOnlyDictionary<Guid, PrinterConnectionRuntimeState> states)
    {
        ActiveConnectionCount = states.Values.Count(x => x.IsConnected);
        StateHasChanged();
    }

    public void Dispose()
    {
        ConnectionManager.StatesChanged -= HandleStatesChanged;
    }
}
