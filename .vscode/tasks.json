{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-blazor",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/MakerPrompt.Blazor/MakerPrompt.Blazor.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "watch-blazor",
      "command": "dotnet",
      "type": "process",
      "args": [
        "watch",
        "--project",
        "${workspaceFolder}/MakerPrompt.Blazor/MakerPrompt.Blazor.csproj"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
